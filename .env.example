# Copy to .env and fill in your values. .env is gitignored.

# aisstream.io WebSocket API key — register at https://aisstream.io
AISSTREAM_API_KEY=your_api_key_here

# DuckDB database path (default: data/processed/mpol.duckdb)
# DB_PATH=data/processed/mpol.duckdb

# Neo4j connection (default: local Docker instance)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# ── LLM provider for analyst briefs (C2) and chat (C6) ────────────────────
# Uncomment one block below. LLM_PROVIDER can be any label — only "anthropic"
# triggers the Anthropic client; everything else uses the OpenAI-compat path.

# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Google Gemini
# LLM_PROVIDER=gemini
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your_gemini_api_key_here
# LLM_MODEL=gemini-2.5-flash-preview-04-17

# Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_API_KEY=your_anthropic_api_key_here
# LLM_MODEL=claude-haiku-4-5-20251001
