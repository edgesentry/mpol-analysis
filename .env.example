# Copy to .env and fill in your values. .env is gitignored.

# aisstream.io WebSocket API key — register at https://aisstream.io
AISSTREAM_API_KEY=your_api_key_here

# DuckDB database path (default: data/processed/mpol.duckdb)
# DB_PATH=data/processed/mpol.duckdb

# ── S3-compatible object storage ────────────────────────────────────────────
# Lance Graph datasets, LanceDB, and output Parquet files are written to S3
# when S3_BUCKET is set.  Leave S3_BUCKET unset to use local paths instead.
#
# Local (MinIO — started automatically by docker compose):
# S3_BUCKET=arktrace
# S3_ENDPOINT=http://minio:9000   # use http://localhost:9000 outside Docker
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_REGION=us-east-1
#
# Cloud (AWS S3 / Cloudflare R2 / GCS):
# S3_BUCKET=your-bucket-name
# S3_ENDPOINT=                    # leave blank for real AWS S3
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_REGION=ap-southeast-1

# ── LLM provider for analyst briefs (C2) and chat (C6) ────────────────────
# Default (no configuration needed): the bundled llamacpp server runs on the
# GGUF model downloaded at container startup.  Nothing to set here.
#
# To use a remote or local model instead, uncomment one block below and set
# the required keys.  LLM_PROVIDER can be any label — only "anthropic" triggers
# the Anthropic client; everything else uses the OpenAI-compatible path.

# ── Remote models ──────────────────────────────────────────────────────────

# Anthropic Claude
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-haiku-4-5-20251001

# Google Gemini
# LLM_PROVIDER=gemini
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_API_KEY=your_gemini_api_key_here
# LLM_MODEL=gemini-2.5-flash-lite

# OpenAI
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ── Local model override (Ollama, LM Studio, etc.) ─────────────────────────
# LLM_PROVIDER=openai
# LLM_BASE_URL=http://host.docker.internal:11434/v1   # Ollama on host
# LLM_API_KEY=local
# LLM_MODEL=qwen2.5:7b

# Hugging Face Hub API key (if using a model from Hugging Face)
HF_TOKEN=hf_xxx
